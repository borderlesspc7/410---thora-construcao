# Environment
ENVIRONMENT=production

# Firebase
FIREBASE_DISABLED=1
# Ou use o JSON minificado em linha única:
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Server
PORT=8000
MAX_FILE_SIZE=52428800

# CORS - Frontend URL (obrigatório em produção se não usar *.netlify.app)
FRONTEND_URL=https://borderles-410.netlify.app
FRONTEND_URLS=https://borderles-410.netlify.app,https://410-thora.netlify.app

# AI
GEMINI_API_KEY=sua-chave-aqui
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# OpenAI (deixe vazio até o cliente fornecer a chave real)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORCAMENTO_MODEL=gpt-4o
OPENAI_ORCAMENTO_TIMEOUT=120

# Redis / Celery (fila persistente de Orçamento Analítico — opcional em dev)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
USE_CELERY_QUEUE=true

# Deploy
RAILWAY_PUBLIC_DOMAIN=seu-backend.railway.app

# Vercel (deploy fullstack: importar a raiz do repositório; VERCEL=1 vem do ambiente)
# Plano Hobby ~10s por função — PDF/IA pesados podem precisar de Pro ou timeouts maiores no painel:
# AI_PROVIDER_TIMEOUT_SECONDS=55
# OPENAI_ORCAMENTO_TIMEOUT=55
